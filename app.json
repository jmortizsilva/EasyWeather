{
  "expo": {
    "name": "EasyWeather",
    "slug": "tiempo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1a2b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jmortizsilva.tiempo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "es",
        "CFBundleLocalizations": ["es"],
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1a2b"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "react-native-bottom-tabs",
      "@react-native-community/datetimepicker",
      "./plugins/withLocalNotificationsOnly",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Tiempo usa tu ubicación para mostrarte la previsión meteorológica de tu zona."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bdc45482-63ad-4db7-b1cf-12e9a55b0479"
      }
    }
  }
}
